# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ShowUp AI

# Mock Solana Config
NEXT_PUBLIC_MOCK_SOL_INITIAL_BALANCE=10
NEXT_PUBLIC_DEFAULT_DEPOSIT_SOL=0.1
